};

let currentPrompt = '';

// Colora i bottoni per genere
document.querySelectorAll('.name-btn').forEach(btn => {
  const nome = btn.dataset.nome;
  const d = PROMPTS.find(x => x.nome === nome);
  if (d) btn.classList.add(d.genere === 'f' ? 'nb-f' : 'nb-m');
});

function showPrompt(btn) {
  document.querySelectorAll('.name-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const nome = btn.dataset.nome;
  const d = PROMPTS.find(x => x.nome === nome);
  if (!d) return;
  currentPrompt = d.prompt;
  document.getElementById('promptBox').innerText = d.prompt;
  document.getElementById('outName').textContent = (d.genere==='f'?'👧':'👦') + ' ' + nome;
  document.getElementById('outTags').textContent =
    MAGIC_LABELS[d.magic] + '  ·  ' + MOVE_LABELS[d.move] + '  ·  🎀 ' + d.color;
  const copyBtn = document.getElementById('copyBtn');
  copyBtn.disabled = false;
  document.getElementById('btnText').textContent = 'Copia prompt';
  copyBtn.classList.remove('copied');
  const btnTop = document.getElementById('copyBtnTop');
  btnTop.disabled = false;
  btnTop.style.opacity = '1';
  btnTop.style.cursor = 'pointer';
}

function copyPrompt() {
  if (!currentPrompt) {
    const btn = document.getElementById('copyBtnTop');
    btn.textContent = '⚠️ Seleziona un nome!';
    setTimeout(() => { btn.textContent = '📋 Copia'; }, 2000);
    return;
  }
  navigator.clipboard.writeText(currentPrompt).then(() => {
    const btn = document.getElementById('copyBtn');
    btn.classList.add('copied');
    document.getElementById('btnText').textContent = '✓ Copiato! Incolla su Grok';
    const btnTop = document.getElementById('copyBtnTop');
    btnTop.style.background = 'linear-gradient(135deg,#6dbf8a,#4aa87a)';
    btnTop.textContent = '✓ Copiato!';
    setTimeout(() => {
      btn.classList.remove('copied');
      document.getElementById('btnText').textContent = 'Copia prompt';
      btnTop.style.background = '';
      btnTop.textContent = '📋 Copia';
    }, 3000);
  }).catch(() => {
    // fallback
    const ta = document.createElement('textarea');
    ta.value = currentPrompt;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    const btnTop2 = document.getElementById('copyBtnTop');
    btnTop2.style.background = 'linear-gradient(135deg,#6dbf8a,#4aa87a)';
    btnTop2.textContent = '✓ Copiato!';
    setTimeout(() => { btnTop2.style.background = ''; btnTop2.textContent = '📋 Copia'; }, 3000);
  });
}

function filterNames(q) {
  const ql = q.toLowerCase();
  let visible = 0;
  document.querySelectorAll('.name-btn').forEach(btn => {
    const match = btn.dataset.nome.toLowerCase().includes(ql);
    btn.style.display = match ? '' : 'none';
    if (match) visible++;
  });
  document.querySelectorAll('.section-label').forEach(lbl => {
    const next = lbl.nextElementSibling;
    lbl.style.display = (next && next.style.display !== 'none') ? '' : 'none';
  });
  document.getElementById('countBadge').textContent = `${visible} nomi trovati`;
}
