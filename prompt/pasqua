<title>Prompt Pasquali 🐰</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Georgia', serif; background: linear-gradient(135deg, #fff8f0, #fef0f5, #f5f0ff); min-height: 100vh; padding: 20px 16px; }
h1 { text-align: center; font-size: 1.4rem; color: #7a5080; margin-bottom: 4px; }
.subtitle { text-align: center; font-size: 0.78rem; color: #b090c0; margin-bottom: 20px; }
.layout { display: flex; gap: 18px; max-width: 1280px; margin: 0 auto; align-items: flex-start; }

/* LISTA */
.list-panel { background: white; border-radius: 16px; box-shadow: 0 6px 24px rgba(160,100,180,0.12); padding: 16px; width: 300px; flex-shrink: 0; position: sticky; top: 20px; max-height: calc(100vh - 40px); display: flex; flex-direction: column; }
.search-box { width: 100%; padding: 8px 12px; border: 1.5px solid #e8d0f0; border-radius: 10px; font-size: 0.85rem; margin-bottom: 12px; outline: none; font-family: 'Georgia', serif; }
.search-box:focus { border-color: #b080d0; }
.list-scroll { overflow-y: auto; flex: 1; scrollbar-width: thin; scrollbar-color: #d0a0e0 transparent; }
.list-scroll::-webkit-scrollbar { width: 5px; }
.list-scroll::-webkit-scrollbar-thumb { background: #d0a0e0; border-radius: 10px; }

.section-label { font-size: 0.68rem; font-weight: bold; color: #b090c0; text-transform: uppercase; letter-spacing: 1px; padding: 8px 4px 4px; }

.name-btn { display: flex; flex-direction: column; width: 100%; padding: 8px 10px; border: 1.5px solid #f0e0f8; border-radius: 10px; background: #fdfaff; cursor: pointer; text-align: left; margin-bottom: 5px; transition: all 0.12s; font-family: 'Georgia', serif; }
.name-btn:hover { background: #f5e8ff; border-color: #c0a0e0; }
.name-btn.active { background: #efe0ff; border-color: #9040c0; }
.nb-name { font-size: 0.9rem; color: #5a3070; font-weight: bold; }
.nb-tags { font-size: 0.66rem; color: #a080b0; margin-top: 2px; }
.nb-f .nb-name { color: #a02060; }
.nb-m .nb-name { color: #2050a0; }

.count-badge { font-size: 0.7rem; color: #a080b0; text-align: center; padding: 8px 0 0; }

/* OUTPUT */
.output-panel { flex: 1; background: white; border-radius: 16px; box-shadow: 0 6px 24px rgba(160,100,180,0.12); padding: 22px; min-height: 500px; }
.out-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 14px; padding-bottom: 12px; border-bottom: 2px solid #f0e0f8; }
.out-title { font-size: 1rem; color: #7a5080; }
.out-meta { text-align: right; }
.out-name-badge { background: #f0e0ff; color: #7a5080; font-size: 0.8rem; padding: 4px 12px; border-radius: 20px; font-family: monospace; display: inline-block; margin-bottom: 4px; }
.out-tags { font-size: 0.7rem; color: #a080b0; }

.prompt-box { font-size: 0.83rem; color: #444; line-height: 1.78; white-space: pre-wrap; max-height: 560px; overflow-y: auto; border: 1.5px solid #f0e0f8; border-radius: 10px; padding: 16px; background: #fdfaff; margin-bottom: 14px; scrollbar-width: thin; scrollbar-color: #d0a0e0 transparent; }
.prompt-box::-webkit-scrollbar { width: 6px; }
.prompt-box::-webkit-scrollbar-thumb { background: #d0a0e0; border-radius: 10px; }
.placeholder { color: #c0a0d0; font-style: italic; font-size: 0.88rem; text-align: center; padding: 80px 20px; }

.btn-copy { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; padding: 13px; background: linear-gradient(135deg, #c070d0, #8040a8); color: white; border: none; border-radius: 12px; font-size: 1rem; font-weight: bold; cursor: pointer; transition: all 0.2s; box-shadow: 0 4px 16px rgba(140,60,180,0.25); font-family: 'Georgia', serif; }
.btn-copy:hover { transform: translateY(-2px); }
.btn-copy:disabled { background: #d0c0e0; cursor: not-allowed; transform: none; box-shadow: none; }
.btn-copy.copied { background: linear-gradient(135deg, #6dbf8a, #4aa87a); }

@media (max-width: 760px) { .layout { flex-direction: column; } .list-panel { width: 100%; position: static; max-height: 300px; } }
</style>
</head>
